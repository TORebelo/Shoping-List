rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ---------- helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function listExists(listId) {
      return exists(/databases/$(database)/documents/lists/$(listId));
    }

    function listData(listId) {
      return get(/databases/$(database)/documents/lists/$(listId)).data;
    }

    function isMember(listId) {
      return isSignedIn()
        && listExists(listId)
        && request.auth.uid in listData(listId).memberIds;
    }

    function isOwner(listId) {
      return isSignedIn()
        && listExists(listId)
        && listData(listId).createdBy == request.auth.uid;
    }

    // Membership check that sees docs written earlier in the same batch;
    // used by create rules for subcollections under a list being created
    // atomically (e.g. the initial owner member doc inside createList).
    function isMemberAfter(listId) {
      return isSignedIn()
        && existsAfter(/databases/$(database)/documents/lists/$(listId))
        && request.auth.uid in getAfter(/databases/$(database)/documents/lists/$(listId)).data.memberIds;
    }

    function inviteMapsTo(code, listId) {
      return exists(/databases/$(database)/documents/inviteCodes/$(code))
        && get(/databases/$(database)/documents/inviteCodes/$(code)).data.listId == listId;
    }

    function onlyFieldsChanged(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    function isValidItemName(name) {
      return name is string && name.size() >= 1 && name.size() <= 80;
    }

    function isValidQuantity(q) {
      return q is string && q.size() <= 20;
    }

    // ---------- users ----------

    match /users/{uid} {
      allow read: if isSelf(uid);

      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.plan == 'free'
        && request.resource.data.listIds is list
        && request.resource.data.listIds.size() == 0
        && request.resource.data.email is string
        && request.resource.data.displayName is string;

      allow update: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.listIds is list
        && request.resource.data.listIds.size() <= 100;

      allow delete: if false;
    }

    // ---------- inviteCodes ----------

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.code == code
        && request.resource.data.listId is string;
      allow update: if false;
      allow delete: if isSignedIn();
    }

    // ---------- lists ----------

    match /lists/{listId} {
      allow get: if isSignedIn()
        && request.auth.uid in resource.data.memberIds;
      // Firestore enforces allow get per matched doc for list queries, so
      // we can expose listing to all authenticated users — the memberIds
      // array-contains filter on the client limits the result set.
      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 60
        && request.resource.data.inviteCode is string
        && request.resource.data.status == 'active'
        && request.resource.data.itemCount == 0;

      allow update: if
        request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() <= 20
        && (
          // Case 1: existing member updating fields.
          isMember(listId)
          // Case 2: non-member joining via invite — adds exactly their own uid.
          || (
            isSignedIn()
            && !(request.auth.uid in resource.data.memberIds)
            && request.resource.data.memberIds.hasAll(resource.data.memberIds)
            && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
            && request.auth.uid in request.resource.data.memberIds
            && inviteMapsTo(request.resource.data.inviteCode, listId)
            && onlyFieldsChanged(['memberIds'])
          )
        )
        && (
          // Status transitions: active → closed only; stay same otherwise.
          request.resource.data.status == resource.data.status
          || (
            resource.data.status == 'active'
            && request.resource.data.status == 'closed'
          )
        )
        && (
          // Item count shifts by ±1 or stays put.
          request.resource.data.itemCount == resource.data.itemCount + 1
          || request.resource.data.itemCount == resource.data.itemCount - 1
          || request.resource.data.itemCount == resource.data.itemCount
        );

      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;

      // ---------- members ----------

      match /members/{memberUid} {
        // Knowing the random 20-char list id is already the capability; we
        // don't need a cross-doc isMember check for reads (also keeps list
        // rules fast and avoids races against the parent list commit).
        allow read: if isSignedIn();

        allow create: if isSelf(memberUid)
          && request.resource.data.uid == memberUid
          && request.resource.data.role in ['owner', 'member']
          && request.resource.data.color is string
          && request.resource.data.displayName is string;

        allow update: if
          (
            isSelf(memberUid)
            && onlyFieldsChanged(['displayName', 'color'])
          )
          || (
            isOwner(listId)
            && onlyFieldsChanged(['role'])
            && request.resource.data.role in ['owner', 'member']
          );

        allow delete: if isSelf(memberUid) || isOwner(listId);
      }

      // ---------- items ----------

      match /items/{itemId} {
        allow read: if isSignedIn();

        allow create: if isMember(listId)
          && request.resource.data.addedBy == request.auth.uid
          && request.resource.data.checked == false
          && isValidItemName(request.resource.data.name)
          && isValidQuantity(request.resource.data.quantity)
          && listData(listId).status == 'active'
          && listData(listId).itemCount < 200;

        allow update: if isMember(listId)
          && onlyFieldsChanged(['checked', 'checkedBy'])
          && request.resource.data.checked is bool
          && (
            (request.resource.data.checked == true
              && request.resource.data.checkedBy == request.auth.uid)
            || (request.resource.data.checked == false
              && request.resource.data.checkedBy == null)
          );

        allow delete: if isMember(listId)
          && (
            resource.data.addedBy == request.auth.uid
            || isOwner(listId)
          );
      }
    }
  }
}
