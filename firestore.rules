rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ---------- helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function householdData(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId)).data;
    }

    function isMember(householdId) {
      return isSignedIn()
        && request.auth.uid in householdData(householdId).memberIds;
    }

    function isOwner(householdId) {
      return isSignedIn()
        && householdData(householdId).createdBy == request.auth.uid;
    }

    function inviteMapsTo(code, householdId) {
      return exists(/databases/$(database)/documents/inviteCodes/$(code))
        && get(/databases/$(database)/documents/inviteCodes/$(code)).data.householdId == householdId;
    }

    function onlyFieldsChanged(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    function isValidItemName(name) {
      return name is string && name.size() >= 1 && name.size() <= 80;
    }

    function isValidQuantity(q) {
      return q is string && q.size() <= 20;
    }

    // ---------- users ----------

    match /users/{uid} {
      allow read: if isSelf(uid);

      allow create: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.plan == 'free'
        && request.resource.data.householdIds is list
        && request.resource.data.householdIds.size() == 0
        && request.resource.data.email is string
        && request.resource.data.displayName is string;

      allow update: if isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.householdIds is list
        && request.resource.data.householdIds.size() <= 50;

      allow delete: if false;
    }

    // ---------- inviteCodes ----------

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.code == code
        && request.resource.data.householdId is string;
      allow update: if false;
      allow delete: if isSignedIn();
    }

    // ---------- households ----------

    match /households/{householdId} {
      allow get: if isSignedIn()
        && request.auth.uid in resource.data.memberIds;
      allow list: if false;

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 60
        && request.resource.data.inviteCode is string
        && request.resource.data.activeListId is string;

      allow update: if
        request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() <= 20
        && (
          // Case 1: existing member updating fields.
          isMember(householdId)
          // Case 2: non-member joining via invite — adds exactly their own uid.
          || (
            isSignedIn()
            && !(request.auth.uid in resource.data.memberIds)
            && request.resource.data.memberIds.hasAll(resource.data.memberIds)
            && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
            && request.auth.uid in request.resource.data.memberIds
            && inviteMapsTo(request.resource.data.inviteCode, householdId)
            && onlyFieldsChanged(['memberIds'])
          )
        );

      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;

      // ---------- members ----------

      match /members/{memberUid} {
        allow read: if isMember(householdId);

        allow create: if isSelf(memberUid)
          && request.resource.data.uid == memberUid
          && request.resource.data.role in ['owner', 'member']
          && request.resource.data.color is string
          && request.resource.data.displayName is string;

        allow update: if
          (
            isSelf(memberUid)
            && onlyFieldsChanged(['displayName', 'color'])
          )
          || (
            isOwner(householdId)
            && onlyFieldsChanged(['role'])
            && request.resource.data.role in ['owner', 'member']
          );

        allow delete: if isSelf(memberUid) || isOwner(householdId);
      }

      // ---------- lists ----------

      match /lists/{listId} {
        allow read: if isMember(householdId);

        allow create: if isMember(householdId)
          && request.resource.data.status == 'active'
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 80
          && request.resource.data.itemCount == 0;

        allow update: if isMember(householdId)
          && (
            (
              resource.data.status == 'active'
              && request.resource.data.status == 'closed'
            )
            || (
              request.resource.data.status == resource.data.status
            )
          )
          && (
            request.resource.data.itemCount == resource.data.itemCount + 1
            || request.resource.data.itemCount == resource.data.itemCount - 1
            || request.resource.data.itemCount == resource.data.itemCount
          );

        allow delete: if isMember(householdId);

        // ---------- items ----------

        match /items/{itemId} {
          allow read: if isMember(householdId);

          allow create: if isMember(householdId)
            && request.resource.data.addedBy == request.auth.uid
            && request.resource.data.checked == false
            && isValidItemName(request.resource.data.name)
            && isValidQuantity(request.resource.data.quantity)
            && get(/databases/$(database)/documents/households/$(householdId)/lists/$(listId)).data.status == 'active'
            && get(/databases/$(database)/documents/households/$(householdId)/lists/$(listId)).data.itemCount < 200;

          allow update: if isMember(householdId)
            && onlyFieldsChanged(['checked', 'checkedBy'])
            && request.resource.data.checked is bool
            && (
              (request.resource.data.checked == true
                && request.resource.data.checkedBy == request.auth.uid)
              || (request.resource.data.checked == false
                && request.resource.data.checkedBy == null)
            );

          allow delete: if isMember(householdId)
            && (
              resource.data.addedBy == request.auth.uid
              || isOwner(householdId)
            );
        }
      }
    }
  }
}
